# API Context Router - Environment Variables

# Required: Firecrawl API Key
# Get yours at: https://firecrawl.dev
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Required: OpenAI API Key
# Get yours at: https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Default OpenAI model for Scout and Harvester
# Default: gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# Optional: Cache settings
# CACHE_ENABLED=true
# CACHE_TTL=86400  # 24 hours in seconds
# CACHE_PATH=./.api-context-router/cache.db

# Optional: Harvester settings
# MAX_PAGES_PER_CRAWL=10
